{
  "expo": {
    "name": "xtrus-fcm",
    "slug": "xtrus-fcm",
    "platform": ["ios", "android"],
    "version": "1.0.0",
    "orientation": "default",
    "icon": "./assets/images/icon.png",
    "scheme": "xtrusfcm",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "userInterfaceStyle": "light",
      "supportsTablet": true,
      "bundleIdentifier": "com.xtrus.fcm",
      "googleServicesFile": "./GoogleService-Info.plist",
      "infoPlist": {
        "UIBackgroundModes": [
          "remote-notification",
          "fetch"
        ],
        "ITSAppUsesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/images/android-icon-foreground.png",
        "backgroundImage": "./assets/images/android-icon-background.png",
        "monochromeImage": "./assets/images/android-icon-monochrome.png"
      },
      "package": "com.xtrus.fcm",
      "googleServicesFile": "./google-services.json",
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "runtimeVersion": {
        "policy": "appVersion"
      },
      "permissions": [
        "RECEIVE_BOOT_COMPLETED"
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/splash-icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#ffffff",
          "dark": {
            "backgroundColor": "#000000"
          }
        }
      ],
      "expo-mail-composer",
      [
        "expo-notifications",
        {
          "icon": "./assets/images/icon.png"
        }
      ],
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-build-properties",
        {
          "ios": {
              "extraPodspecOptions": {
              "modular_headers": "true"
            },
            "podfileProperties": {
              "CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES": "YES",
              "GCC_PREPROCESSOR_DEFINITIONS": "$(inherited) CLANG_ALLOW_NON_MODULAR_INCLUDES_IN_FRAMEWORK_MODULES=YES"
            }
          },
          "android": {
            "enableMultiDex": true,
            "compileSdkVersion": 35,
            "targetSdkVersion": 35,
            "buildToolsVersion": "35.0.0"
          }
        }
      ],
      [
        "@react-native-firebase/app",
        {
          "ios": { "googleServicesFile": "./GoogleService-Info.plist" },
          "android": { "googleServicesFile": "./google-services.json" }
        }
      ],
      [
        "@react-native-firebase/messaging",
        {
          "ios": { "skipAppDelegateInit": true }
        }
      ],
      "expo-font",
      "@sentry/react-native"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "d167503b-b101-4653-aa21-c9cfb0056012"
      }
    }
  }
}
